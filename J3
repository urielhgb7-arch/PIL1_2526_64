!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Tâches J3 — Priorités</title>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@700;800&family=IBM+Plex+Mono:wght@400;600&family=DM+Sans:wght@400;500;600&display=swap" rel="stylesheet"/>
<style>
  :root {
    --bg: #0a0a0f;
    --surface: #111118;
    --card: #16161f;
    --border: #222230;
    --p1: #ff3b3b;
    --p1-glow: rgba(255,59,59,.18);
    --p1-dim: rgba(255,59,59,.08);
    --p2: #ff8c00;
    --p2-glow: rgba(255,140,0,.18);
    --p2-dim: rgba(255,140,0,.08);
    --p3: #7c5cfc;
    --p3-glow: rgba(124,92,252,.18);
    --p3-dim: rgba(124,92,252,.08);
    --text: #e8e8f0;
    --muted: #55556a;
    --done-text: #3a3a50;
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    background: var(--bg);
    font-family: 'DM Sans', sans-serif;
    color: var(--text);
    min-height: 100vh;
    padding: 1.5rem 1rem 3rem;
  }

  /* Grain overlay */
  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.04'/%3E%3C/svg%3E");
    pointer-events: none;
    z-index: 0;
    opacity: .4;
  }

  .wrapper { position: relative; z-index: 1; max-width: 560px; margin: 0 auto; }

  /* ── HEADER ── */
  header { margin-bottom: 2rem; }

  .day-chip {
    display: inline-flex;
    align-items: center;
    gap: .4rem;
    font-family: 'IBM Plex Mono', monospace;
    font-size: .7rem;
    font-weight: 600;
    letter-spacing: .1em;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: .6rem;
  }
  .day-chip::before {
    content: '';
    display: inline-block;
    width: 6px; height: 6px;
    border-radius: 50%;
    background: var(--p3);
    box-shadow: 0 0 8px var(--p3);
    animation: pulse 2s infinite;
  }
  @keyframes pulse {
    0%,100% { opacity: 1; transform: scale(1); }
    50% { opacity: .5; transform: scale(.7); }
  }

  h1 {
    font-family: 'Syne', sans-serif;
    font-size: 1.65rem;
    font-weight: 800;
    line-height: 1.2;
    color: var(--text);
    margin-bottom: .35rem;
  }
  h1 em { font-style: normal; color: #7c5cfc; }

  .subtitle {
    font-size: .82rem;
    color: var(--muted);
    font-family: 'IBM Plex Mono', monospace;
  }

  /* ── PROGRESS GLOBAL ── */
  .global-progress {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: .9rem 1.1rem;
    margin-bottom: 1.75rem;
    display: flex;
    align-items: center;
    gap: 1rem;
  }
  .progress-stats {
    display: flex;
    gap: 1.2rem;
    flex-shrink: 0;
  }
  .stat { text-align: center; }
  .stat-num {
    font-family: 'Syne', sans-serif;
    font-size: 1.3rem;
    font-weight: 800;
    line-height: 1;
  }
  .stat-num.red { color: var(--p1); }
  .stat-num.orange { color: var(--p2); }
  .stat-num.purple { color: var(--p3); }
  .stat-label {
    font-size: .62rem;
    color: var(--muted);
    font-family: 'IBM Plex Mono', monospace;
    text-transform: uppercase;
    letter-spacing: .06em;
    margin-top: .15rem;
  }
  .progress-bar-wrap { flex: 1; }
  .progress-bar-label {
    display: flex;
    justify-content: space-between;
    font-size: .7rem;
    color: var(--muted);
    margin-bottom: .3rem;
    font-family: 'IBM Plex Mono', monospace;
  }
  .progress-bar {
    height: 6px;
    background: var(--border);
    border-radius: 99px;
    overflow: hidden;
  }
  .progress-fill {
    height: 100%;
    border-radius: 99px;
    background: linear-gradient(90deg, var(--p1), var(--p2), var(--p3));
    transition: width .5s cubic-bezier(.4,0,.2,1);
  }

  /* ── SECTION ── */
  .section { margin-bottom: 1.4rem; }

  .section-label {
    display: flex;
    align-items: center;
    gap: .55rem;
    margin-bottom: .
65rem;
  }
  .section-label .pill {
    font-family: 'IBM Plex Mono', monospace;
    font-size: .72rem;
    font-weight: 600;
    letter-spacing: .06em;
    padding: .28rem .7rem;
    border-radius: 99px;
    text-transform: uppercase;
  }
  .pill.p1 { background: var(--p1-dim); color: var(--p1); border: 1px solid rgba(255,59,59,.25); }
  .pill.p2 { background: var(--p2-dim); color: var(--p2); border: 1px solid rgba(255,140,0,.25); }
  .pill.p3 { background: var(--p3-dim); color: var(--p3); border: 1px solid rgba(124,92,252,.25); }

  .section-desc {
    font-size: .73rem;
    color: var(--muted);
    font-family: 'IBM Plex Mono', monospace;
  }
  .section-count {
    margin-left: auto;
    font-family: 'IBM Plex Mono', monospace;
    font-size: .68rem;
    color: var(--muted);
  }

  /* ── TASK CARD ── */
  .task {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 11px;
    padding: .85rem 1rem;
    display: flex;
    align-items: flex-start;
    gap: .8rem;
    cursor: pointer;
    transition: border-color .2s, background .2s, transform .1s;
    margin-bottom: .5rem;
    user-select: none;
    animation: slideIn .3s ease both;
  }
  @keyframes slideIn {
    from { opacity: 0; transform: translateY(8px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  .task:nth-child(1) { animation-delay: .05s; }
  .task:nth-child(2) { animation-delay: .1s; }
  .task:nth-child(3) { animation-delay: .15s; }
  .task:nth-child(4) { animation-delay: .2s; }

  .task:active { transform: scale(.98); }

  .task.p1-task:hover { border-color: rgba(255,59,59,.4); background: var(--p1-dim); }
  .task.p2-task:hover { border-color: rgba(255,140,0,.4); background: var(--p2-dim); }
  .task.p3-task:hover { border-color: rgba(124,92,252,.4); background: var(--p3-dim); }

  .task.done {
    opacity: .42;
    background: var(--surface);
  }
  .task.done .task-text { text-decoration: line-through; color: var(--done-text); }

  /* Checkbox */
  .cb {
    width: 22px; height: 22px;
    border-radius: 6px;
    border: 2px solid var(--border);
    background: transparent;
    flex-shrink: 0;
    display: flex; align-items: center; justify-content: center;
    transition: all .2s;
    margin-top: 1px;
  }
  .task.done.p1-task .cb { background: var(--p1); border-color: var(--p1); box-shadow: 0 0 10px var(--p1-glow); }
  .task.done.p2-task .cb { background: var(--p2); border-color: var(--p2); box-shadow: 0 0 10px var(--p2-glow); }
  .task.done.p3-task .cb { background: var(--p3); border-color: var(--p3); box-shadow: 0 0 10px var(--p3-glow); }
  .cb svg { display: none; }
  .task.done .cb svg { display: block; }

  .task-body { flex: 1; }
  .task-text {
    font-size: .875rem;
    line-height: 1.5;
    color: var(--text);
    margin-bottom: .35rem;
  }
  .task-meta {
    display: flex;
    align-items: center;
    gap: .5rem;
    flex-wrap: wrap;
  }
  .tag {
    font-family: 'IBM Plex Mono', monospace;
    font-size: .63rem;
    padding: .15rem .45rem;
    border-radius: 4px;
    background: var(--surface);
    border: 1px solid var(--border);
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: .04em;
  }

  /* Left accent bar */
  .task { position: relative; overflow: hidden; }
  .task::before {
    content: '';
    position: absolute;
    left: 0; top: 0; bottom: 0;
    width: 3px;
    border-radius: 99px 0 0 99px;
    transition: opacity .2s;
  }
  .p1-task::before { background: var(--p1); }
  .p2-task::before { background: var(--p2); }
  .p3-task::before { background: var(--p3); }
  .task.done::before { opacity: .25; }

  /* ── RESET BTN ── */
  .reset-btn {
    display: block;
    width: 100%;
    margin-top: 1.5rem;
    padding: .75rem;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 10px;
    color: var(--muted);
    font-family: 'IBM Plex Mono', monospace;
    font-size: .75rem;
    text-transform: uppercase;
    letter-spacing: .08em;
    cursor: pointer;
    transition: all .2s;
  }
  .
reset-btn:hover { border-color: var(--p3); color: var(--p3); }
</style>
</head>
<body>
<div class="wrapper">

  <!-- HEADER -->
  <header>
    <div class="day-chip">Sprint d'Intégration — Jour 3</div>
    <h1>Tâches <em>J3</em><br>QA &amp; Doc</h1>
    <div class="subtitle">Dev F — Débutant · Doc &amp; QA</div>
  </header>

  <!-- PROGRESS GLOBAL -->
  <div class="global-progress">
    <div class="progress-stats">
      <div class="stat">
        <div class="stat-num red" id="cnt-p1">0</div>
        <div class="stat-label">P1</div>
      </div>
      <div class="stat">
        <div class="stat-num orange" id="cnt-p2">0</div>
        <div class="stat-label">P2</div>
      </div>
      <div class="stat">
        <div class="stat-num purple" id="cnt-p3">0</div>
        <div class="stat-label">P3</div>
      </div>
    </div>
    <div class="progress-bar-wrap">
      <div class="progress-bar-label">
        <span>Avancement</span>
        <span id="pct-label">0 / 6</span>
      </div>
      <div class="progress-bar">
        <div class="progress-fill" id="global-fill" style="width:0%"></div>
      </div>
    </div>
  </div>

  <!-- ══ P1 — CRITIQUE ══ -->
  <div class="section">
    <div class="section-label">
      <span class="pill p1">P1 — Critique</span>
      <span class="section-desc">À terminer aujourd'hui absolument</span>
      <span class="section-count" id="lbl-p1">0/2</span>
    </div>

    <div class="task p1-task" onclick="toggle(this,'p1')">
      <div class="cb">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="3.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
      </div>
      <div class="task-body">
        <div class="task-text">Créer les 4 comptes de démonstration (Kofi, Aïcha, Moussa, Fatou) en BDD</div>
        <div class="task-meta">
          <span class="tag">BDD</span>
          <span class="tag">Comptes démo</span>
        </div>
      </div>
    </div>

    <div class="task p1-task" onclick="toggle(this,'p1')">
      <div class="cb">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="3.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
      </div>
      <div class="task-body">
        <div class="task-text">Tester l'ensemble des scénarios et lister les anomalies prioritaires</div>
        <div class="task-meta">
          <span class="tag">QA</span>
          <span class="tag">Tests</span>
        </div>
      </div>
    </div>
  </div>

  <!-- ══ P2 — IMPORTANT ══ -->
  <div class="section">
    <div class="section-label">
      <span class="pill p2">P2 — Important</span>
      <span class="section-desc">À faire si P1 terminés</span>
      <span class="section-count" id="lbl-p2">0/2</span>
    </div>

    <div class="task p2-task" onclick="toggle(this,'p2')">
      <div class="cb">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="3.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
      </div>
      <div class="task-body">
        <div class="task-text">Rédiger les premières sections du rapport technique (architecture et BDD)</div>
        <div class="task-meta">
          <span class="tag">Doc</span>
          <span class="tag">Rapport</span>
        </div>
      </div>
    </div>

    <div class="task p2-task" onclick="toggle(this,'p2')">
      <div class="cb">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="3.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
      </div>
      <div class="task-body">
        <div class="task-text">Documenter les anomalies trouvées avec captures d'écran et descriptions</div>
        <div class="task-meta">
          <span class="tag">Doc</span>
          <span class="tag">QA</span>
        </div>
      </div>
    </div>
  </div>

  <!-- ══ P3 — OPTIONNEL ══ -->
  <div class="section">
<div class="section-label">
      <span class="pill p3">P3 — Optionnel</span>
      <span class="section-desc">Si temps disponible</span>
      <span class="section-count" id="lbl-p3">0/2</span>
    </div>

    <div class="task p3-task" onclick="toggle(this,'p3')">
      <div class="cb">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="3.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
      </div>
      <div class="task-body">
        <div class="task-text">Préparer le squelette du manuel utilisateur (sections + titres)</div>
        <div class="task-meta">
          <span class="tag">Manuel</span>
          <span class="tag">Doc</span>
        </div>
      </div>
    </div>

    <div class="task p3-task" onclick="toggle(this,'p3')">
      <div class="cb">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="3.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
      </div>
      <div class="task-body">
        <div class="task-text">Vérifier la cohérence des données de test entre les 4 comptes démo</div>
        <div class="task-meta">
          <span class="tag">QA</span>
          <span class="tag">Vérification</span>
        </div>
      </div>
    </div>
  </div>

  <button class="reset-btn" onclick="resetAll()">↺ Réinitialiser toutes les tâches</button>

</div>

<script>
  const counters = { p1: 0, p2: 0, p3: 0 };
  const totals   = { p1: 2, p2: 2, p3: 2 };

  function toggle(el, prio) {
    const wasDone = el.classList.contains('done');
    el.classList.toggle('done');
    counters[prio] += wasDone ? -1 : 1;
    update();
  }

  function update() {
    // Compteurs par priorité
    document.getElementById('cnt-p1').textContent = counters.p1;
    document.getElementById('cnt-p2').textContent = counters.p2;
    document.getElementById('cnt-p3').textContent = counters.p3;
    document.getElementById('lbl-p1').textContent = counters.p1 + '/' + totals.p1;
    document.getElementById('lbl-p2').textContent = counters.p2 + '/' + totals.p2;
    document.getElementById('lbl-p3').textContent = counters.p3 + '/' + totals.p3;

    // Barre globale
    const total = totals.p1 + totals.p2 + totals.p3;
    const done  = counters.p1 + counters.p2 + counters.p3;
    const pct   = Math.round(done / total * 100);
    document.getElementById('global-fill').style.width = pct + '%';
    document.getElementById('pct-label').textContent = done + ' / ' + total;
  }

  function resetAll() {
    document.querySelectorAll('.task.done').forEach(t => t.classList.remove('done'));
    counters.p1 = counters.p2 = counters.p3 = 0;
    update();
